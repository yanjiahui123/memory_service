# ─── 数据库（必填）─────────────────────────────────────────────────────────────
# PostgreSQL 连接串，部署时替换为实际地址和密码
FM_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/forum_memory
FM_DATABASE_ECHO=false

# ─── Elasticsearch ────────────────────────────────────────────────────────────
FM_ES_URL=http://localhost:9200
FM_ES_INDEX_PREFIX=forum_memory
FM_ES_ENABLED=true
# 如果 ES 启用了认证，取消注释并填写
# FM_ES_USERNAME=elastic
# FM_ES_PASSWORD=YOUR_ES_PASSWORD
# FM_ES_VERIFY_CERTS=true

# ─── LLM 配置 ─────────────────────────────────────────────────────────────────
# 提供者: openai 或 custom
FM_LLM_PROVIDER=openai
FM_LLM_API_KEY=sk-your-api-key
FM_LLM_MAIN_MODEL=gpt-4o
FM_LLM_EMBEDDING_MODEL=text-embedding-3-small
FM_EMBEDDING_DIMENSION=1536
FM_LLM_TIMEOUT=60

# ─── 自定义 LLM 提供者（当 FM_LLM_PROVIDER=custom 时必填）──────────────────────
# FM_CUSTOM_LLM_URL=http://your-llm-endpoint/v1/chat/completions
# FM_CUSTOM_EMBED_URL=http://your-embed-endpoint/v1/embeddings
# FM_CUSTOM_RERANK_URL=http://your-rerank-endpoint/v1/rerank
# FM_CUSTOM_API_KEY=your-custom-api-key
# FM_CUSTOM_LLM_MODEL=your-model-name
# FM_CUSTOM_EMBED_MODEL=your-embed-model
# FM_CUSTOM_RERANK_MODEL=your-rerank-model

# ─── JWT 认证（生产环境建议开启）──────────────────────────────────────────────
FM_JWT_ENABLED=false
# 开启 JWT 时必填，请使用随机安全密钥（如 openssl rand -hex 32）
# FM_JWT_SECRET_KEY=your-random-secret-key
# FM_JWT_ALGORITHM=HS256
# FM_JWT_EXPIRE_HOURS=24

# ─── 论坛默认配置 ─────────────────────────────────────────────────────────────
FM_THREAD_TIMEOUT_DAYS=7
FM_SIMILARITY_THRESHOLD=0.75
FM_WRONG_FEEDBACK_THRESHOLD=3

# ─── 文件上传 ─────────────────────────────────────────────────────────────────
# FM_UPLOAD_DIR=uploads
# FM_UPLOAD_MAX_SIZE_MB=5

# ─── RAG 知识库（可选）────────────────────────────────────────────────────────
# FM_RAG_BASE_URL=http://your-rag-service/api
# FM_RAG_TIMEOUT=30

# ─── 记忆生命周期（天数）──────────────────────────────────────────────────────
# FM_COLD_INACTIVE_DAYS=180
# FM_ARCHIVE_INACTIVE_DAYS=365

# ─── Dagster 实例存储（生产环境使用 PostgreSQL）────────────────────────────────
# 配合 dagster.yaml 使用，默认 Dagster 使用本地 SQLite
# DAGSTER_PG_HOST=localhost
# DAGSTER_PG_PORT=5432
# DAGSTER_PG_DB=dagster
# DAGSTER_PG_USERNAME=postgres
# DAGSTER_PG_PASSWORD=YOUR_DAGSTER_PASSWORD
